# vim: set filetype=yaml:
# Content should be UTF-8.
version: 1

database:
  # Optional DSN for an existing MariaDB/MySQL service. If empty, metabib
  # discovers MariaDB binaries and starts a private local server automatically.
  dsn: ""

  # MariaDB connection defaults. Managed mode uses a private Unix socket on Unix
  # and localhost TCP with a generated free port on Windows. External services
  # use these values as configured.
  host: '{{ if eq .OS "windows" }}127.0.0.1{{ else }}{{ joinPath .ProjectDir "data" "metabib.sock" }}{{ end }}'
  port: '{{ if eq .OS "windows" }}{{ freeLocalPort }}{{ else }}0{{ end }}'
  protocol: '{{ if eq .OS "windows" }}tcp{{ else }}unix{{ end }}'
  user: "root"
  password: ""
  name: "flibusta"

  # Managed local MariaDB instance. When enabled, metabib uses a private datadir
  # and does not require a system database service.
  managed: true
  data_dir: '{{ joinPath .ProjectDir "data" "mariadb" }}'

  # Use a temporary managed datadir under the OS temp directory and remove it on
  # shutdown. When false, data_dir is reused across runs.
  temporary: false

  # Managed-server support files. socket is used only with Unix managed mode.
  # pid_file and log_file are used by the managed MariaDB server on all OSes.
  socket: '{{ if eq .OS "windows" }}""{{ else }}{{ joinPath .ProjectDir "data" "metabib.sock" }}{{ end }}'
  pid_file: '{{ joinPath .ProjectDir "data" "metabib.pid" }}'
  log_file: '{{ joinPath .ProjectDir "data" "metabib-mariadb.log" }}'

  # Optional full paths to MariaDB binaries. If empty, metabib first searches
  # ./mariadb recursively under the startup directory, then PATH.
  server_path: ""
  install_db_path: ""
  client_path: ""

  # Connection pool used by metabib while reading metadata. 0 lets database/sql
  # use its default for that particular setting.
  max_open_connections: 32
  max_idle_connections: 32
  connection_max_lifetime_seconds: 0

fetch:
  # Remote library profiles used by `metabib fetch`. Patterns must capture the
  # file name as the first regexp group. library_name is used for generated SQL
  # dump directories when --tosql is omitted.
  libraries:
    - name: flibusta
      library_name: flibusta
      archive_pattern: '(?i)<a\s+href="(f(?:\.fb2)*\.[0-9]+-[0-9]+\.zip)">'
      sql_pattern: '(?i)<a\s+href="(lib\.lib\w+\.sql\.gz)">'
      archive_url: http://flibusta.is/daily/
      sql_url: http://flibusta.is/sql/
      proxy: ""

processing:
  # Parse FB2 description metadata from archive entries.
  parse_fb2: true

  # Preserve full parsed FB2 <description> tree. Turning this off keeps only
  # title-info and is faster, but loses document-info/publish-info/custom-info.
  fb2_description_tree: true

  # Calculate MD5 of the uncompressed archive entry content. For FB2 this reuses
  # the parser stream, but still has to drain the whole entry after description.
  archive_content_md5: true

  manifests:
    # Empty keeps compressed archive manifests next to archives and replaces the
    # extension: /path/lib.zip -> /path/lib.manifest.zst. When set, manifests are
    # placed in this directory using the archive base name.
    archive_dir: ""

    # Empty keeps compressed database manifest in the SQL dump directory as
    # database.manifest.zst. When set, database.manifest.zst is placed in this
    # directory.
    database_dir: ""

  # Parallel workers for database manifest creation.
  database_workers: '{{ .CPUs }}'

  # Number of books loaded by one worker query batch during database-only export.
  database_batch_size: 256

  # Parallel workers for archive entry processing.
  archive_workers: '{{ .CPUs }}'

  # Number of archive entries processed by one worker batch.
  archive_batch_size: 256

  # Buffer size in bytes for reading uncompressed archive entry content.
  archive_read_buffer_size: 262144

inpx:
  # Apply MyHomeLib-compatible field length limits when generating INPX.
  quick_fix: true

  # Go text/template collection.info template. Available values are DatabaseName,
  # DumpDate, and DisplayDate; slim-sprig template functions are available. The
  # default starts with UTF-8 BOM (\ufeff) for MyHomeLib/lib2inpx compatibility.
  comment_template: "\ufeff{{ .DatabaseName }} FB2 - {{ .DisplayDate }}\r\n{{ .DatabaseName }}_{{ .DumpDate }}\r\n65536\r\nЛокальные архивы библиотеки {{ .DatabaseName }} (FB2) {{ .DisplayDate }}"

  # Go text/template version.info template. Available values and functions are
  # the same as comment_template.
  version_template: "{{ .DumpDate }}\r\n"

  limits:
    author_name: 128
    author_middle: 128
    author_family: 128
    title: 150
    keywords: 255
    sequence: 80

logging:
  # Controls terminal (stdout, stderr) output. Application debug messages and
  # MariaDB process/client output require "debug"; "normal" shows info and above.
  console:
    # "none" suppresses terminal logging.
    level: normal

  # Controls logging to a file. Application debug messages and MariaDB
  # process/client output require "debug"; "normal" writes info and above.
  file:
    destination: '{{ joinPath .ProjectDir "metabib.log" }}'
    level: debug
    mode: append
