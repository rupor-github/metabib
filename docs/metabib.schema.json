{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rupor-github/metabib/docs/metabib.schema.json",
  "title": "metabib source cache record",
  "type": "object",
  "required": ["schema", "id", "sources"],
  "properties": {
    "schema": {"const": "metabib.record/1"},
    "id": {"$ref": "#/$defs/record_id"},
    "sources": {"$ref": "#/$defs/record_sources"},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false,
  "$defs": {
    "record_id": {
      "type": "object",
      "required": ["library"],
      "properties": {
        "library": {"type": "string"},
        "book_id": {"type": "integer"},
        "file_name": {"type": "string"},
        "extension": {"type": "string"},
        "archive": {"$ref": "#/$defs/archive_info"}
      },
      "additionalProperties": false
    },
    "archive_info": {
      "type": "object",
      "required": ["path", "entry"],
      "properties": {
        "path": {"type": "string"},
        "entry": {"type": "string"},
        "index": {"type": "integer"},
        "compressed_size": {"type": "integer"},
        "uncompressed_size": {"type": "integer"},
        "content_md5": {"type": "string"},
        "modified": {"type": "string"}
      },
      "additionalProperties": false
    },
    "record_sources": {
      "type": "object",
      "required": ["database", "fb2"],
      "properties": {
        "database": {"$ref": "#/$defs/database_source"},
        "fb2": {"$ref": "#/$defs/fb2_source"}
      },
      "additionalProperties": false
    },
    "database_source": {
      "type": "object",
      "required": ["present"],
      "properties": {
        "present": {"type": "boolean"},
        "book": {"$ref": "#/$defs/database_book"},
        "authors": {"type": "array", "items": {"$ref": "#/$defs/contributor"}},
        "translators": {"type": "array", "items": {"$ref": "#/$defs/contributor"}},
        "illustrators": {"type": "array", "items": {"$ref": "#/$defs/contributor"}},
        "genres": {"type": "array", "items": {"$ref": "#/$defs/database_genre"}},
        "sequences": {"type": "array", "items": {"$ref": "#/$defs/database_sequence"}},
        "rating": {"$ref": "#/$defs/database_rating"},
        "filenames": {"type": "array", "items": {"type": "string"}},
        "joined_books": {"type": "array", "items": {"$ref": "#/$defs/database_joined_book"}}
      },
      "additionalProperties": false
    },
    "database_book": {
      "type": "object",
      "required": ["book_id", "file_size", "title"],
      "properties": {
        "book_id": {"type": "integer"},
        "file_size": {"type": "integer"},
        "time": {"type": "string"},
        "title": {"type": "string"},
        "lang": {"type": "string"},
        "src_lang": {"type": "string"},
        "file_type": {"type": "string"},
        "year": {"type": "integer"},
        "deleted": {"type": "string"},
        "file_author": {"type": "string"},
        "keywords": {"type": "string"},
        "md5": {"type": "string"},
        "modified": {"type": "string"},
        "replaced_by": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "contributor": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "first_name": {"type": "string"},
        "middle_name": {"type": "string"},
        "last_name": {"type": "string"},
        "nick_name": {"type": "string"},
        "uid": {"type": "integer"},
        "email": {"type": "string"},
        "homepage": {"type": "string"},
        "gender": {"type": "string"},
        "master_id": {"type": "integer"},
        "position": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "database_genre": {
      "type": "object",
      "required": ["id", "code"],
      "properties": {
        "id": {"type": "integer"},
        "code": {"type": "string"},
        "translated_code": {"type": "string"},
        "description": {"type": "string"},
        "meta": {"type": "string"}
      },
      "additionalProperties": false
    },
    "database_sequence": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {"type": "integer"},
        "name": {"type": "string"},
        "number": {"type": "integer"},
        "level": {"type": "integer"},
        "type": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "database_rating": {
      "type": "object",
      "required": ["count"],
      "properties": {
        "average": {"type": "number"},
        "count": {"type": "integer"},
        "min": {"type": "integer"},
        "max": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "database_joined_book": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {"type": "integer"},
        "time": {"type": "string"},
        "bad_id": {"type": "integer"},
        "good_id": {"type": "integer"},
        "real_id": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "fb2_source": {
      "type": "object",
      "required": ["present"],
      "properties": {
        "present": {"type": "boolean"},
        "description": {"$ref": "#/$defs/fb2_description"}
      },
      "additionalProperties": false
    },
    "fb2_description": {
      "type": "object",
      "properties": {
        "title_info": {"$ref": "#/$defs/fb2_title_info"},
        "src_title_info": {"$ref": "#/$defs/fb2_title_info"},
        "document_info": {"$ref": "#/$defs/fb2_document_info"},
        "publish_info": {"$ref": "#/$defs/fb2_publish_info"},
        "custom_info": {"type": "array", "items": {"$ref": "#/$defs/fb2_custom_info"}},
        "output": {"type": "array", "items": {"$ref": "#/$defs/fb2_output"}}
      },
      "additionalProperties": false
    },
    "fb2_title_info": {
      "type": "object",
      "properties": {
        "genres": {"type": "array", "items": {"$ref": "#/$defs/fb2_genre"}},
        "authors": {"type": "array", "items": {"$ref": "#/$defs/fb2_person"}},
        "title": {"type": "string"},
        "annotation": {"type": "string"},
        "keywords": {"type": "string"},
        "date": {"$ref": "#/$defs/fb2_date"},
        "language": {"type": "string"},
        "source_language": {"type": "string"},
        "translators": {"type": "array", "items": {"$ref": "#/$defs/fb2_person"}},
        "sequences": {"type": "array", "items": {"$ref": "#/$defs/fb2_sequence"}}
      },
      "additionalProperties": false
    },
    "fb2_genre": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": {"type": "string"},
        "match": {"type": "string"}
      },
      "additionalProperties": false
    },
    "fb2_person": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "first_name": {"type": "string"},
        "middle_name": {"type": "string"},
        "last_name": {"type": "string"},
        "nick_name": {"type": "string"},
        "home_pages": {"type": "array", "items": {"type": "string"}},
        "emails": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "fb2_date": {
      "type": "object",
      "properties": {
        "text": {"type": "string"},
        "value": {"type": "string"}
      },
      "additionalProperties": false
    },
    "fb2_sequence": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "number": {"type": "string"},
        "language": {"type": "string"},
        "sequences": {"type": "array", "items": {"$ref": "#/$defs/fb2_sequence"}}
      },
      "additionalProperties": false
    },
    "fb2_document_info": {
      "type": "object",
      "properties": {
        "authors": {"type": "array", "items": {"$ref": "#/$defs/fb2_person"}},
        "program_used": {"type": "string"},
        "date": {"$ref": "#/$defs/fb2_date"},
        "src_urls": {"type": "array", "items": {"type": "string"}},
        "src_ocr": {"type": "string"},
        "id": {"type": "string"},
        "version": {"type": "string"},
        "history": {"type": "string"},
        "publishers": {"type": "array", "items": {"$ref": "#/$defs/fb2_person"}}
      },
      "additionalProperties": false
    },
    "fb2_publish_info": {
      "type": "object",
      "properties": {
        "book_name": {"type": "string"},
        "publisher": {"type": "string"},
        "city": {"type": "string"},
        "year": {"type": "string"},
        "isbn": {"type": "string"},
        "sequences": {"type": "array", "items": {"$ref": "#/$defs/fb2_sequence"}}
      },
      "additionalProperties": false
    },
    "fb2_custom_info": {
      "type": "object",
      "properties": {
        "type": {"type": "string"},
        "text": {"type": "string"}
      },
      "additionalProperties": false
    },
    "fb2_output": {
      "type": "object",
      "properties": {
        "mode": {"type": "string"},
        "include_all": {"type": "string"},
        "price": {"type": "string"},
        "currency": {"type": "string"},
        "parts": {"type": "array", "items": {"$ref": "#/$defs/fb2_output_part"}},
        "output_document_classes": {"type": "array", "items": {"$ref": "#/$defs/fb2_output_document_class"}}
      },
      "additionalProperties": false
    },
    "fb2_output_part": {
      "type": "object",
      "properties": {
        "type": {"type": "string"},
        "href": {"type": "string"},
        "include": {"type": "string"}
      },
      "additionalProperties": false
    },
    "fb2_output_document_class": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "create": {"type": "string"},
        "price": {"type": "string"},
        "parts": {"type": "array", "items": {"$ref": "#/$defs/fb2_output_part"}}
      },
      "additionalProperties": false
    }
  }
}
