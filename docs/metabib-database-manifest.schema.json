{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rupor-github/metabib/docs/metabib-database-manifest.schema.json",
  "title": "metabib database manifest JSONL",
  "oneOf": [
    {"$ref": "#/$defs/header"},
    {"$ref": "metabib.schema.json"}
  ],
  "$defs": {
    "header": {
      "type": "object",
      "required": ["schema", "source", "processing", "created", "records"],
      "properties": {
        "schema": {"const": "metabib.database_manifest/1"},
        "source": {
          "type": "object",
          "required": ["dump_dir", "dumps"],
          "properties": {
            "dump_dir": {"type": "string"},
            "dump_date": {"type": "string"},
            "database_format": {"enum": ["flibusta-current", "librusec-current"]},
            "dumps": {
              "type": "array",
              "items": {"$ref": "#/$defs/dump"}
            }
          },
          "additionalProperties": false
        },
        "processing": {"$ref": "#/$defs/processing"},
        "created": {"type": "string"},
        "records": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "dump": {
      "type": "object",
      "required": ["path", "name", "modified", "md5"],
      "properties": {
        "path": {"type": "string"},
        "name": {"type": "string"},
        "dump_date": {"type": "string"},
        "dump_completed": {"type": "string"},
        "modified": {"type": "string"},
        "md5": {"type": "string"}
      },
      "additionalProperties": false
    },
    "processing": {
      "type": "object",
      "required": ["parse_fb2", "fb2_description_tree", "archive_content_md5"],
      "properties": {
        "parse_fb2": {"type": "boolean"},
        "fb2_description_tree": {"type": "boolean"},
        "archive_content_md5": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  }
}
